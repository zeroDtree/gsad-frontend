# API origin for Axios `baseURL`.
#   空 — 同源 /api，由 Vite 代理到 VITE_PROXY_TARGET（联调真实后端）
#   https://...apifoxmock.com/... — 直连 Apifox 云端 Mock（见 npm run dev:apifox、openapi/README.md）
VITE_API_BASE_URL=

# Board polling interval in milliseconds (30_000–300_000; default 45_000).
VITE_BOARD_POLL_MS=45000

# Vite dev proxy target for `/api` (see vite.config.ts).
VITE_PROXY_TARGET=http://localhost:8080
