{
  "openapi": "3.0.3",
  "info": {
    "title": "GSAD API",
    "version": "1.0.0",
    "description": "GPU Server Access Dashboard — API contract for `npm run generate:api-types`. Aligns with Spring Boot gsad controllers; compare with backend `/v3/api-docs` when the server is running."
  },
  "servers": [
    {
      "url": "http://localhost:5173",
      "description": "Vite dev server (proxies /api to VITE_PROXY_TARGET)"
    },
    {
      "url": "http://localhost:8080",
      "description": "Backend direct (default VITE_PROXY_TARGET)"
    }
  ],
  "tags": [
    { "name": "Authentication", "description": "User login" },
    { "name": "Admin", "description": "Admin-only operations (JWT with admin role)" },
    { "name": "Servers", "description": "Public server board (no auth)" },
    { "name": "Applications", "description": "Resource access applications (JWT required)" }
  ],
  "paths": {
    "/api/auth/login": {
      "post": {
        "tags": ["Authentication"],
        "operationId": "login",
        "summary": "Login and obtain JWT",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthResponseEnvelope" },
                "example": {
                  "code": "",
                  "message": "ok",
                  "data": {
                    "token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJlbWFpbCI6ImRlbW9AZXhhbXBsZS5jb20iLCJyb2xlcyI6W119.demo-signature",
                    "email": "demo@example.com",
                    "roles": []
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/admin/users": {
      "get": {
        "tags": ["Admin"],
        "operationId": "listAdminUsers",
        "summary": "List users (paginated, admin only)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "cohort", "in": "query", "schema": { "type": "string" } },
          {
            "name": "status",
            "in": "query",
            "schema": { "type": "string", "enum": ["ACTIVE", "INACTIVE", "all"] }
          },
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "page_size", "in": "query", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": {
          "200": {
            "description": "Paginated user list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PageResultAdminUserEnvelope" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/admin/users/{id}": {
      "patch": {
        "tags": ["Admin"],
        "operationId": "updateAdminUser",
        "summary": "Update user (admin only)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateAdminUserRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated user",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AdminUserEnvelope" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Admin"],
        "operationId": "deleteAdminUser",
        "summary": "Delete user (admin only)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64" }
          },
          {
            "name": "revokeSsh",
            "in": "query",
            "schema": { "type": "boolean", "default": false },
            "description": "When true, revoke SSH/GPU access before delete; may return 409 if revokes are pending"
          }
        ],
        "responses": {
          "204": { "description": "User deleted" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": {
            "description": "Revoke in progress; retry delete later",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DeleteAdminUserResponseEnvelope" }
              }
            }
          }
        }
      }
    },
    "/api/admin/users/bulk-disable": {
      "post": {
        "tags": ["Admin"],
        "operationId": "bulkDisableUsers",
        "summary": "Bulk disable users (admin only)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BulkUserActionRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk disable result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BulkDisableUsersResponseEnvelope" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/admin/users/bulk-enable": {
      "post": {
        "tags": ["Admin"],
        "operationId": "bulkEnableUsers",
        "summary": "Bulk enable users (admin only)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BulkUserActionRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk enable result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BulkEnableUsersResponseEnvelope" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/admin/users/bulk-delete": {
      "post": {
        "tags": ["Admin"],
        "operationId": "bulkDeleteUsers",
        "summary": "Bulk delete users (admin only)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BulkDeleteUsersRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk delete result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BulkDeleteUsersResponseEnvelope" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/admin/users/import": {
      "post": {
        "tags": ["Admin"],
        "operationId": "importUsers",
        "summary": "Import users from CSV (admin only)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["file"],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "CSV with columns: email,linux_username,display_name,student_id,cohort,initial_password,roles"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Import result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UserImportResponseEnvelope" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/api/servers": {
      "get": {
        "tags": ["Servers"],
        "operationId": "listServers",
        "summary": "List all servers with GPU summary",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Server list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ServerListEnvelope" },
                "example": {
                  "code": "",
                  "message": "ok",
                  "data": {
                    "items": [
                      {
                        "id": "gpu-mock-001",
                        "resourceLevel": "H100",
                        "status": "ONLINE",
                        "lastReportedAt": "2026-05-18T08:00:00Z",
                        "collectedAt": "2026-05-18T08:00:00Z",
                        "summary": { "gpuCount": 8, "avgUtil": 0.42, "avgMemUsedMb": 32768 },
                        "gpus": [
                          {
                            "index": 0,
                            "name": "NVIDIA H100",
                            "avgUtil": 0.35,
                            "memUsedMb": 40960,
                            "memTotalMb": 81920
                          }
                        ]
                      }
                    ]
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/applications": {
      "post": {
        "tags": ["Applications"],
        "operationId": "createApplication",
        "summary": "Submit a new resource application",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": false,
            "description": "UUID for idempotent submission; the frontend sends a fresh value on each submit.",
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateApplicationRequest" },
              "example": {
                "serverId": "gpu-mock-001"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Application created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApplicationResponseEnvelope" },
                "example": {
                  "code": "",
                  "message": "ok",
                  "data": {
                    "id": "app-mock001",
                    "serverId": "gpu-mock-001",
                    "resourceLevel": "H100",
                    "auditStatus": "APPROVED",
                    "comment": null,
                    "credentialsReady": false,
                    "createdAt": "2026-05-18T08:00:00Z",
                    "updatedAt": "2026-05-18T08:00:00Z"
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      }
    },
    "/api/applications/{id}": {
      "delete": {
        "tags": ["Applications"],
        "operationId": "revokeApplication",
        "summary": "Revoke or cancel my application",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Application revoked or cancelled",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApplicationResponseEnvelope" },
                "example": {
                  "code": "",
                  "message": "ok",
                  "data": {
                    "id": "app-mock001",
                    "serverId": "gpu-mock-001",
                    "resourceLevel": "H100",
                    "auditStatus": "REVOKING",
                    "comment": null,
                    "credentialsReady": false,
                    "createdAt": "2026-05-18T08:00:00Z",
                    "updatedAt": "2026-05-18T09:00:00Z"
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      }
    },
    "/api/applications/mine": {
      "get": {
        "tags": ["Applications"],
        "operationId": "listMyApplications",
        "summary": "List my applications (paginated)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "required": false,
            "description": "Filter by audit status",
            "schema": { "$ref": "#/components/schemas/AuditStatus" }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Page number (1-based)",
            "schema": { "type": "integer", "minimum": 1, "default": 1 }
          },
          {
            "name": "page_size",
            "in": "query",
            "required": false,
            "description": "Page size (max 100)",
            "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 20 }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated application list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PageResultApplicationEnvelope" },
                "example": {
                  "code": "",
                  "message": "ok",
                  "data": {
                    "items": [
                      {
                        "id": "app-mock001",
                        "serverId": "1",
                        "resourceLevel": "H100",
                        "auditStatus": "ACTIVE",
                        "comment": null,
                        "serverIp": "10.0.0.101",
                        "sshUsername": "ubuntu",
                        "initialPassword": "demo-password",
                        "credentialsReady": true,
                        "createdAt": "2026-05-18T08:00:00Z",
                        "updatedAt": "2026-05-18T08:00:00Z"
                      }
                    ],
                    "total": 1,
                    "page": 1,
                    "pageSize": 20
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT from login; store as GSAD_TOKEN in the frontend."
      }
    },
    "schemas": {
      "ErrorCode": {
        "type": "string",
        "enum": [
          "INVALID_ARGUMENT",
          "UNAUTHORIZED",
          "FORBIDDEN",
          "NOT_FOUND",
          "STATE_CONFLICT",
          "RATE_LIMITED",
          "INTERNAL_ERROR"
        ]
      },
      "AuditStatus": {
        "type": "string",
        "enum": [
          "APPROVED",
          "ACTIVE",
          "REVOKING",
          "REVOKED",
          "CANCELLED",
          "FAILED_GRANT",
          "FAILED_REVOKE"
        ]
      },
      "ServerStatus": {
        "type": "string",
        "enum": ["ONLINE", "OFFLINE", "MAINTENANCE"]
      },
      "ResourceLevel": {
        "type": "string",
        "description": "GPU tier enum used when creating applications",
        "enum": ["H100", "A100", "L40S", "L4", "T4"]
      },
      "ErrorEnvelope": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "$ref": "#/components/schemas/ErrorCode" },
          "message": { "type": "string" },
          "data": { "nullable": true }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "format": "password" }
        }
      },
      "UserImportError": {
        "type": "object",
        "required": ["row", "reason"],
        "properties": {
          "row": { "type": "integer" },
          "reason": { "type": "string" }
        }
      },
      "UserImportPassword": {
        "type": "object",
        "required": ["email", "initialPassword"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "initialPassword": { "type": "string" }
        }
      },
      "UserImportResponse": {
        "type": "object",
        "required": ["created", "skipped", "errors", "passwords"],
        "properties": {
          "created": { "type": "integer" },
          "skipped": { "type": "integer" },
          "errors": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/UserImportError" }
          },
          "passwords": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/UserImportPassword" }
          }
        }
      },
      "UserImportResponseEnvelope": {
        "type": "object",
        "required": ["code", "message", "data"],
        "properties": {
          "code": { "type": "string", "example": "" },
          "message": { "type": "string", "example": "ok" },
          "data": { "$ref": "#/components/schemas/UserImportResponse" }
        }
      },
      "UserStatus": {
        "type": "string",
        "enum": ["ACTIVE", "INACTIVE"]
      },
      "AdminUserVO": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "email": { "type": "string", "format": "email" },
          "linuxUsername": { "type": "string" },
          "status": { "$ref": "#/components/schemas/UserStatus" },
          "cohort": { "type": "string", "nullable": true },
          "displayName": { "type": "string", "nullable": true },
          "studentId": { "type": "string", "nullable": true },
          "notes": { "type": "string", "nullable": true },
          "label": { "type": "string", "nullable": true },
          "activeAccessCount": { "type": "integer", "format": "int64" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "AdminUserEnvelope": {
        "type": "object",
        "required": ["code", "message", "data"],
        "properties": {
          "code": { "type": "string", "example": "" },
          "message": { "type": "string", "example": "ok" },
          "data": { "$ref": "#/components/schemas/AdminUserVO" }
        }
      },
      "UpdateAdminUserRequest": {
        "type": "object",
        "properties": {
          "displayName": { "type": "string", "nullable": true },
          "cohort": { "type": "string", "nullable": true },
          "notes": { "type": "string", "nullable": true },
          "label": { "type": "string", "nullable": true },
          "status": { "$ref": "#/components/schemas/UserStatus" }
        }
      },
      "PageResultAdminUser": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/AdminUserVO" }
          },
          "total": { "type": "integer", "format": "int64" },
          "page": { "type": "integer" },
          "pageSize": { "type": "integer" }
        }
      },
      "PageResultAdminUserEnvelope": {
        "type": "object",
        "required": ["code", "message", "data"],
        "properties": {
          "code": { "type": "string", "example": "" },
          "message": { "type": "string", "example": "ok" },
          "data": { "$ref": "#/components/schemas/PageResultAdminUser" }
        }
      },
      "DeleteAdminUserResponse": {
        "type": "object",
        "properties": {
          "deleted": { "type": "boolean" },
          "pendingRevokes": { "type": "integer" },
          "message": { "type": "string" }
        }
      },
      "DeleteAdminUserResponseEnvelope": {
        "type": "object",
        "required": ["code", "message", "data"],
        "properties": {
          "code": { "type": "string", "example": "STATE_CONFLICT" },
          "message": { "type": "string" },
          "data": { "$ref": "#/components/schemas/DeleteAdminUserResponse" }
        }
      },
      "BulkUserActionRequest": {
        "type": "object",
        "properties": {
          "ids": {
            "type": "array",
            "items": { "type": "integer", "format": "int64" }
          },
          "selectAll": { "type": "boolean" },
          "cohort": { "type": "string" },
          "status": { "type": "string", "enum": ["ACTIVE", "INACTIVE", "all"] }
        }
      },
      "BulkDeleteUsersRequest": {
        "type": "object",
        "properties": {
          "ids": {
            "type": "array",
            "items": { "type": "integer", "format": "int64" }
          },
          "selectAll": { "type": "boolean" },
          "cohort": { "type": "string" },
          "status": { "type": "string", "enum": ["ACTIVE", "INACTIVE", "all"] },
          "revokeSsh": { "type": "boolean", "default": false }
        }
      },
      "BulkUserError": {
        "type": "object",
        "properties": {
          "userId": { "type": "integer", "format": "int64" },
          "email": { "type": "string", "format": "email" },
          "reason": { "type": "string" }
        }
      },
      "BulkDisableUsersResponse": {
        "type": "object",
        "properties": {
          "disabled": { "type": "integer" },
          "skipped": { "type": "integer" },
          "errors": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/BulkUserError" }
          }
        }
      },
      "BulkDisableUsersResponseEnvelope": {
        "type": "object",
        "required": ["code", "message", "data"],
        "properties": {
          "code": { "type": "string", "example": "" },
          "message": { "type": "string", "example": "ok" },
          "data": { "$ref": "#/components/schemas/BulkDisableUsersResponse" }
        }
      },
      "BulkEnableUsersResponse": {
        "type": "object",
        "properties": {
          "enabled": { "type": "integer" },
          "skipped": { "type": "integer" },
          "errors": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/BulkUserError" }
          }
        }
      },
      "BulkEnableUsersResponseEnvelope": {
        "type": "object",
        "required": ["code", "message", "data"],
        "properties": {
          "code": { "type": "string", "example": "" },
          "message": { "type": "string", "example": "ok" },
          "data": { "$ref": "#/components/schemas/BulkEnableUsersResponse" }
        }
      },
      "BulkDeleteUsersResponse": {
        "type": "object",
        "properties": {
          "deleted": { "type": "integer" },
          "pending": { "type": "integer" },
          "skipped": { "type": "integer" },
          "errors": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/BulkUserError" }
          }
        }
      },
      "BulkDeleteUsersResponseEnvelope": {
        "type": "object",
        "required": ["code", "message", "data"],
        "properties": {
          "code": { "type": "string", "example": "" },
          "message": { "type": "string", "example": "ok" },
          "data": { "$ref": "#/components/schemas/BulkDeleteUsersResponse" }
        }
      },
      "AuthResponse": {
        "type": "object",
        "required": ["token", "email", "roles"],
        "properties": {
          "token": { "type": "string", "description": "JWT access token" },
          "email": { "type": "string", "format": "email" },
          "roles": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "AuthResponseEnvelope": {
        "type": "object",
        "required": ["code", "message", "data"],
        "properties": {
          "code": {
            "type": "string",
            "description": "Empty string on success",
            "example": ""
          },
          "message": { "type": "string", "example": "ok" },
          "data": { "$ref": "#/components/schemas/AuthResponse" }
        }
      },
      "CreateApplicationRequest": {
        "type": "object",
        "required": ["serverId"],
        "description": "Submit application for a specific GPU server (Jackson camelCase).",
        "properties": {
          "serverId": {
            "type": "string",
            "description": "Target server id from GET /api/servers"
          },
          "sshPassword": {
            "type": "string",
            "minLength": 8,
            "maxLength": 128,
            "description": "Optional SSH password for the granted account"
          }
        }
      },
      "ApplicationVO": {
        "type": "object",
        "description": "Application record; SSH fields appear when auditStatus is ACTIVE.",
        "properties": {
          "id": { "type": "string" },
          "serverId": { "type": "string" },
          "resourceLevel": { "type": "string" },
          "auditStatus": { "$ref": "#/components/schemas/AuditStatus" },
          "comment": { "type": "string", "nullable": true },
          "serverIp": { "type": "string", "description": "Shown in UI when ACTIVE" },
          "sshUsername": { "type": "string" },
          "initialPassword": { "type": "string" },
          "credentialsReady": { "type": "boolean" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "ApplicationResponseEnvelope": {
        "type": "object",
        "required": ["code", "message", "data"],
        "properties": {
          "code": { "type": "string", "example": "" },
          "message": { "type": "string", "example": "ok" },
          "data": { "$ref": "#/components/schemas/ApplicationVO" }
        }
      },
      "PageResultApplication": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ApplicationVO" }
          },
          "total": { "type": "integer", "format": "int64" },
          "page": { "type": "integer" },
          "pageSize": { "type": "integer" }
        }
      },
      "PageResultApplicationEnvelope": {
        "type": "object",
        "required": ["code", "message", "data"],
        "properties": {
          "code": { "type": "string", "example": "" },
          "message": { "type": "string", "example": "ok" },
          "data": { "$ref": "#/components/schemas/PageResultApplication" }
        }
      },
      "GpuSummaryBlock": {
        "type": "object",
        "properties": {
          "gpuCount": { "type": "integer" },
          "avgUtil": {
            "type": "number",
            "format": "double",
            "description": "Average GPU utilization, 0~1"
          },
          "avgMemUsedMb": { "type": "integer" }
        }
      },
      "GpuRow": {
        "type": "object",
        "properties": {
          "index": { "type": "integer" },
          "name": { "type": "string" },
          "avgUtil": { "type": "number", "format": "double", "description": "0~1" },
          "memUsedMb": { "type": "integer" },
          "memTotalMb": { "type": "integer" }
        }
      },
      "ServerVO": {
        "type": "object",
        "description": "Public server row with stable id and GPU metrics.",
        "properties": {
          "id": {
            "type": "string",
            "description": "Stable server id used when submitting applications"
          },
          "resourceLevel": { "type": "string" },
          "status": { "$ref": "#/components/schemas/ServerStatus" },
          "lastReportedAt": { "type": "string", "format": "date-time", "nullable": true },
          "collectedAt": { "type": "string", "format": "date-time", "nullable": true },
          "summary": { "$ref": "#/components/schemas/GpuSummaryBlock", "nullable": true },
          "gpus": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/GpuRow" }
          }
        }
      },
      "ServerListData": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ServerVO" }
          }
        }
      },
      "ServerListEnvelope": {
        "type": "object",
        "required": ["code", "message", "data"],
        "properties": {
          "code": { "type": "string", "example": "" },
          "message": { "type": "string", "example": "ok" },
          "data": { "$ref": "#/components/schemas/ServerListData" }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Invalid argument or validation failure",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorEnvelope" },
            "example": {
              "code": "INVALID_ARGUMENT",
              "message": "email: must not be blank",
              "data": null
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Not authenticated or invalid credentials",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorEnvelope" },
            "example": {
              "code": "UNAUTHORIZED",
              "message": "Not authenticated",
              "data": null
            }
          }
        }
      },
      "Forbidden": {
        "description": "Insufficient permissions",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorEnvelope" },
            "example": {
              "code": "FORBIDDEN",
              "message": "权限不足",
              "data": null
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorEnvelope" },
            "example": {
              "code": "NOT_FOUND",
              "message": "资源不存在或已变更",
              "data": null
            }
          }
        }
      },
      "Conflict": {
        "description": "State conflict (e.g. duplicate registration)",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorEnvelope" },
            "example": {
              "code": "STATE_CONFLICT",
              "message": "状态已变更，请刷新后重试",
              "data": null
            }
          }
        }
      },
      "TooManyRequests": {
        "description": "Rate limited",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorEnvelope" },
            "example": {
              "code": "RATE_LIMITED",
              "message": "请求过于频繁，请稍后再试",
              "data": null
            }
          }
        }
      }
    }
  }
}
